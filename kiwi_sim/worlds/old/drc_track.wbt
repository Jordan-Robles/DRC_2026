Robot {
  name "kiwi_robot"
  translation -4.750 4.750 0.025
  rotation 0 0 1 0
  children [
    DEF BODY Shape { appearance PBRAppearance { baseColor 0.1 0.5 0.9 roughness 0.4 metalness 0.2 } geometry Cylinder { radius 0.10 height 0.06 } }
    Transform { translation 0 0.09 0.02 children [ Shape { appearance PBRAppearance { baseColor 1 0.3 0.1 } geometry Sphere { radius 0.02 } } ] }
    DEF W0 HingeJoint { jointParameters HingeJointParameters { axis 0 1 0 anchor 0 0.09 0 } device [ RotationalMotor { name "wheel0" maxVelocity 20 maxTorque 10 } PositionSensor { name "wheel0_sensor" } ] endPoint Solid { translation 0 0.09 0 rotation 1 0 0 1.5708 children [ Shape { appearance PBRAppearance { baseColor 0.15 0.15 0.15 } geometry Cylinder { radius 0.025 height 0.018 } } ] name "wheel0_solid" boundingObject Cylinder { radius 0.025 height 0.018 } physics Physics { density 200 } } }
    DEF W1 HingeJoint { jointParameters HingeJointParameters { axis -0.866025 -0.5 0 anchor -0.07794 -0.045 0 } device [ RotationalMotor { name "wheel1" maxVelocity 20 maxTorque 10 } PositionSensor { name "wheel1_sensor" } ] endPoint Solid { translation -0.07794 -0.045 0 rotation 0.5 -0.866025 0 1.5708 children [ Shape { appearance PBRAppearance { baseColor 0.15 0.15 0.15 } geometry Cylinder { radius 0.025 height 0.018 } } ] name "wheel1_solid" boundingObject Cylinder { radius 0.025 height 0.018 } physics Physics { density 200 } } }
    DEF W2 HingeJoint { jointParameters HingeJointParameters { axis 0.866025 -0.5 0 anchor 0.07794 -0.045 0 } device [ RotationalMotor { name "wheel2" maxVelocity 20 maxTorque 10 } PositionSensor { name "wheel2_sensor" } ] endPoint Solid { translation 0.07794 -0.045 0 rotation 0.5 0.866025 0 1.5708 children [ Shape { appearance PBRAppearance { baseColor 0.15 0.15 0.15 } geometry Cylinder { radius 0.025 height 0.018 } } ] name "wheel2_solid" boundingObject Cylinder { radius 0.025 height 0.018 } physics Physics { density 200 } } }
    GPS { name "gps" type "satellite" }
    Gyro { name "gyro" }
  ]
  boundingObject USE BODY
  physics Physics { density -1 mass 1.2 centerOfMass [ 0 0 0 ] }
  controller "kiwi_controller"
}
